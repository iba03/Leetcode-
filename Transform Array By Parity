/*
Problem Statement:
Given an integer array nums, transform the array such that:
1. Replace all even numbers with 0
2. Replace all odd numbers with 1
3. Sort the resulting array in non-decreasing order

Return the transformed array.

Example:
Input: [3,1,2,4]
Step 1: [1,1,0,0]
Step 2 (sorted): [0,0,1,1]
Output: [0,0,1,1]
*/

class Solution {
    public int[] transformArray(int[] nums) {

        // Variables for iteration
        int i = 0, j = 0;

        // Step 1: Convert even numbers → 0, odd numbers → 1
        for(i = 0; i < nums.length; i++)
        {
            if(nums[i] % 2 == 0)
            {
                nums[i] = 0; // even → 0
            }
            else
                nums[i] = 1; // odd → 1
        }

        // Step 2: Sort the array (ascending order)
        // Using simple comparison-based sorting (like bubble/selection style)
        for(i = 0; i < nums.length - 1; i++)
        {
            for(j = i + 1; j < nums.length; j++)
            {
                // Swap if current element is greater than next
                if(nums[i] >= nums[j])
                {
                    int temp = nums[i];
                    nums[i] = nums[j];
                    nums[j] = temp;
                }
            }
        }

        // Return the transformed and sorted array
        return nums;
    }
}
