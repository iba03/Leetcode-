// LeetCode Problem: First Missing Positive
// https://leetcode.com/problems/first-missing-positive/
class Solution {
    public int firstMissingPositive(int[] nums) {
        // Get the length of the array
        int n = nums.length;

        // Step 1: Replace invalid numbers
        // We only care about numbers in the range [1, n]
        // So replace numbers <= 0 or > n with a dummy value (n+1)
        for(int i = 0; i < n; i++)
        {
            if(nums[i] > n || nums[i] <= 0)
            {
                nums[i] = n + 1;
            }
        }

        // Step 2: Mark presence of numbers
        // For each number in range [1, n], mark its index (num-1) as negative
        // This indicates that the number exists in the array
        for(int i = 0; i < n; i++)
        {
            int num = Math.abs(nums[i]); // Use absolute value to avoid already marked negatives

            if(num > 0 && num <= n)
            {
                // Mark the index (num-1) as negative to indicate presence
                nums[num - 1] = Math.abs(nums[num - 1]) * -1;
            }
        }

        // Step 3: Find the first missing positive
        // The first index with a positive value indicates the missing number
        for(int i = 0; i < n; i++)
        {
            if(nums[i] > 0)
            {
                // Index i corresponds to number (i+1)
                return i + 1;
            }
        }

        // If all numbers from 1 to n are present, return n+1
        return n + 1;
    }
}
