// LeetCode Problem: Find the Difference
// Link: https://leetcode.com/problems/find-the-difference/

/*
Problem Statement:
You are given two strings s and t.

String t is generated by randomly shuffling string s and then adding one more character.

Return the character that was added to t.

Example:
Input: s = "abcd", t = "abcde"
Output: 'e'
*/

class Solution {
    public char findTheDifference(String s, String t) {

        // sum → stores total value of characters in string s
        // sum1 → stores total value of characters in string t
        int sum = 0, sum1 = 0, i = 0;

        // Calculate sum of characters in s
        for(i = 0; i < s.length(); i++)
        {
            // Convert character to integer value using ASCII offset
            sum = sum + (s.charAt(i) - '0');
        }

        // Calculate sum of characters in t
        for(i = 0; i < t.length(); i++)
        {
            sum1 = sum1 + (t.charAt(i) - '0');
        }

        // Difference gives the extra character value
        int diff = sum1 - sum;

        // Convert back to character
        char ch = (char)(diff + '0');

        return ch;
    }
}
