// LeetCode Problem: Maximum Subarray
// Link: https://leetcode.com/problems/maximum-subarray/

/*
Problem Statement:
Given an integer array nums, find the contiguous subarray 
(containing at least one number) which has the largest sum 
and return its sum.

Example:
Input: nums = [-2,1,-3,4,-1,2,1,-5,4]
Output: 6
Explanation: [4,-1,2,1] has the largest sum = 6
*/

int maxSubArray(int* nums, int numsSize) {

    // Loop variables (j is unused but kept as per original code)
    int i = 0, j = 0;

    // cur → current subarray sum
    // max → maximum subarray sum found so far
    int cur, max;

    // Initialize both with first element
    cur = max = nums[i];

    // Traverse from second element
    for(i = 1; i < numsSize; i++)
    {
        // Decide whether to:
        // 1. Extend the current subarray
        // 2. Start a new subarray from current element
        if(cur + nums[i] > nums[i])
        {
            cur = cur + nums[i]; // extend
        }
        else
        {
            cur = nums[i]; // start new subarray
        }

        // Update maximum sum if current is greater
        if(cur > max)
        {
            max = cur;
        }
    }

    // Return the maximum subarray sum
    return max;
}
