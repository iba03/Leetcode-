class Solution {
    public int maxProfit(int[] prices) {
    int i=0,j=0;
    int pro=0;
    int min=prices[0],curr=prices[0];
    for(i=1;i<prices.length;i++)
    {
        if(prices[i]<min)
        {
            min=prices[i];
        }
        if(prices[i]-min>pro)
        {
            pro=prices[i]-min;
        }
    }
        return pro;
    }
}
