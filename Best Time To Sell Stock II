// LeetCode Problem: Best Time to Buy and Sell Stock II
// Link: https://leetcode.com/problems/best-time-to-buy-and-sell-stock-ii/

/*
Problem Statement:
You are given an integer array prices where prices[i] is the price of a given stock on the i-th day.

On each day, you may decide to buy and/or sell the stock.
You can only hold at most one share of the stock at any time.
However, you can buy it and then immediately sell it on the same day.

Find and return the maximum profit you can achieve.

Example:
Input: prices = [7,1,5,3,6,4]
Output: 7
Explanation:
Buy on day 2 (price = 1) and sell on day 3 (price = 5) → profit = 4
Buy on day 4 (price = 3) and sell on day 5 (price = 6) → profit = 3
Total profit = 7
*/

class Solution {
    public int maxProfit(int[] prices) {

        // Variable to store total profit
        int profit = 0;

        // Start from second day (index 1)
        int i = 1;

        // Traverse through price array
        for(i = 1; i < prices.length; i++)
        {
            // If today's price is higher than yesterday's price,
            // we can make profit by buying yesterday and selling today
            if(prices[i-1] < prices[i])
            {
                // Add the profit difference
                profit = profit + (prices[i] - prices[i-1]);
            }
        }

        // Return the total accumulated profit
        return profit;
    }
}
